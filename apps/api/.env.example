# Core runtime
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# Chain / contracts — Arbitrum One mainnet
CHAIN_ID=42161
RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
GENESIS_VAULT_ADDRESS=0xe164997D48395B4e24aB0f9F66c57DEA38C5E041
STRATEGY_ROUTER_ADDRESS=0xD7ff8383eBBE3B1023d95A3f14c32D9941Ac9e84
COMPLIANCE_REGISTRY_ADDRESS=0x6D58678562387c400964737884E78f2f12e1c495
AAVE_V3_ADAPTER_ADDRESS=0xa6F089338Ae75306217336054B36C02c3Bc5554D
BALANCER_V3_ADAPTER_ADDRESS=0x6291Ed9FC028F872D14B1da79de60a63e7Ec6624
TBILL_ADAPTER_ADDRESS=0xD27d55DB27F09443DB3Bf9f959bA0A3eB8Cc9A0e
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
# Address with OPERATOR_ROLE on GenesisVault — needed for activateAccount + harvest
OPERATOR_PRIVATE_KEY=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=genesis_ledger
DB_USER=genesis
DB_PASSWORD=CHANGE_ME
DB_SSL=false
DB_POOL_MAX=20

# Redis / Kafka
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@localhost:6379
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
SERVICE_NAME=genesis-api

# Webhooks / providers
ONFIDO_WEBHOOK_TOKEN=
CHAINALYSIS_WEBHOOK_SECRET=
CHAINALYSIS_API_KEY=
GENESIS_ADMIN_API_KEY=

# Zero Hash provider
ZEROHASH_API_BASE_URL=https://api.cert.zerohash.com
ZEROHASH_API_KEY=
ZEROHASH_API_SECRET=
ZEROHASH_API_PASSPHRASE=
ZEROHASH_PLATFORM_CODE=
ZEROHASH_WEBHOOK_SECRET=
ZEROHASH_CORRIDORS=US-MX,US-PH
REMITTANCE_PROVIDER=

# Privy auth verification
PRIVY_APP_ID=
PRIVY_JWKS_URL=
PRIVY_EXPECTED_ISSUER=
PRIVY_ALLOW_UNVERIFIED_DEV=true

# Alerting / telemetry
SLACK_HARVEST_WEBHOOK=
SLACK_RECON_WEBHOOK=
PAGERDUTY_INTEGRATION_KEY=
DATADOG_API_KEY=
HARVEST_CRON_SCHEDULE=*/5 * * * *
CRON_STATUS_PORT=4001

# CORS
CORS_ORIGIN=*
