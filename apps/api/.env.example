# Core runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Chain / contracts
CHAIN_ID=421614
RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
GENESIS_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
STRATEGY_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
COMPLIANCE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
OPERATOR_PRIVATE_KEY=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=genesis_ledger
DB_USER=genesis
DB_PASSWORD=genesis_dev_password
DB_SSL=false
DB_POOL_MAX=20

# Redis / Kafka
REDIS_PASSWORD=genesis_dev_redis
REDIS_URL=redis://:genesis_dev_redis@localhost:6379
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
SERVICE_NAME=genesis-api

# Webhooks / providers
ONFIDO_WEBHOOK_TOKEN=
CHAINALYSIS_WEBHOOK_SECRET=
CHAINALYSIS_API_KEY=
GENESIS_ADMIN_API_KEY=

# Zero Hash provider
ZEROHASH_API_BASE_URL=https://api.cert.zerohash.com
ZEROHASH_API_KEY=
ZEROHASH_API_SECRET=
ZEROHASH_API_PASSPHRASE=
ZEROHASH_PLATFORM_CODE=
ZEROHASH_WEBHOOK_SECRET=
ZEROHASH_CORRIDORS=US-MX,US-PH
REMITTANCE_PROVIDER=

# Privy auth verification
PRIVY_APP_ID=
PRIVY_JWKS_URL=
PRIVY_EXPECTED_ISSUER=
PRIVY_ALLOW_UNVERIFIED_DEV=true

# Alerting / telemetry
SLACK_HARVEST_WEBHOOK=
SLACK_RECON_WEBHOOK=
PAGERDUTY_INTEGRATION_KEY=
DATADOG_API_KEY=
HARVEST_CRON_SCHEDULE=*/5 * * * *
CRON_STATUS_PORT=4001

# CORS
CORS_ORIGIN=*
