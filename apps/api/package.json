{
  "name": "@genesis/api",
  "version": "1.0.0",
  "description": "Genesis Reserve — API Gateway (Express)",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "db:migrate": "ts-node scripts/db-migrate.ts",
    "db:seed": "ts-node scripts/seed.ts",
    "cron:harvest": "ts-node src/cron/harvest.cron.ts",
    "service:reconciliation": "ts-node src/reconciliation/index.ts",
    "service:event-processor": "ts-node src/event-processor/index.ts",
    "test:e2e": "RUN_E2E=true mocha tests/e2e/*.test.ts --timeout 120000 --require ts-node/register",
    "test:api": "mocha tests/e2e/deposit-reserve-payout.test.ts --timeout 30000 --require ts-node/register",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^6.2.2",
    "kafkajs": "^2.2.4",
    "node-cron": "^3.0.3",
    "p-retry": "^6.2.0",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.57.2",
    "chai": "^4.4.1",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.2.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
