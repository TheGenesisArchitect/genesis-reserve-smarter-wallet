{
  "name": "@genesis/web",
  "version": "0.1.0",
  "private": true,
  "description": "Genesis Reserve Digital Wallet — Privy + ERC-4337 integration",
  "scripts": {
    "dev": "next dev -p 3200",
    "clean": "node -e \"require('fs').rmSync('.next-local',{ recursive: true, force: true })\"",
    "build": "npm run clean && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run __tests__ --exclude **/*-db-smoke*",
    "test:bff-proxy": "vitest run __tests__/bff-backend.test.ts",
    "test:phase2": "vitest run __tests__/phase2-protocol-gates.test.ts",
    "test:smoke:db": "vitest run __tests__/card-service-db-smoke.test.ts __tests__/card-routes-db-smoke.test.ts",
    "keys:rotate:dry-run": "node scripts/rotate-compliance-roles.mjs",
    "keys:rotate:execute": "node scripts/rotate-compliance-roles.mjs --execute"
  },
  "dependencies": {
    "@privy-io/react-auth": "^1.81.0",
    "@privy-io/wagmi": "^0.2.13",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@tanstack/react-query": "^5.56.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@zerodev/ecdsa-validator": "^5.4.0",
    "@zerodev/permissions": "^5.4.0",
    "@zerodev/sdk": "^5.5.8",
    "array.prototype.flatmap": "^1.3.3",
    "clsx": "^2.1.0",
    "es-abstract": "^1.24.0",
    "next": "14.2.33",
    "permissionless": "^0.2.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stripe": "^22.1.0",
    "tailwindcss": "^3.4.0",
    "viem": "^2.47.6",
    "wagmi": "^2.12.0",
    "zod": "^4.3.6",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
