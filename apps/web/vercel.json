{
    "buildCommand": "npm run build",
    "installCommand": "npm install --legacy-peer-deps",
    "framework": "nextjs",
    "headers": [
        {
            "source": "/(.*\\.html)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ]
}