# ── PRIVY ──────────────────────────────────────────────────────────────────
# Get from dashboard.privy.io → Settings → App ID
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# ── ZERODEV (Paymaster + Bundler) ───────────────────────────────────────────
# Get from dashboard.zerodev.app → Project → RPC Endpoint
# Create a project on Arbitrum One, copy the full URL
NEXT_PUBLIC_ZERODEV_PROJECT_ID=your_zerodev_project_id_here
NEXT_PUBLIC_ZERODEV_BUNDLER_URL=https://rpc.zerodev.app/api/v2/bundler/your_project_id
NEXT_PUBLIC_ZERODEV_PAYMASTER_URL=https://rpc.zerodev.app/api/v2/paymaster/your_project_id

# ── ALCHEMY (RPC + WebSocket) ────────────────────────────────────────────────
# Arbitrum One mainnet RPC — already in use per roadmap
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here
NEXT_PUBLIC_ALCHEMY_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here
# Optional comma-separated fallbacks per chain (used when primary RPC is slow/down)
NEXT_PUBLIC_ARBITRUM_RPC_FALLBACKS=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC_FALLBACKS=https://sepolia-rollup.arbitrum.io/rpc
NEXT_PUBLIC_ETHEREUM_RPC_FALLBACKS=https://cloudflare-eth.com
NEXT_PUBLIC_BASE_RPC_FALLBACKS=https://mainnet.base.org
NEXT_PUBLIC_POLYGON_RPC_FALLBACKS=https://polygon-rpc.com
NEXT_PUBLIC_OPTIMISM_RPC_FALLBACKS=https://mainnet.optimism.io
# If true, use public fallbacks before paid RPC endpoints.
NEXT_PUBLIC_RPC_PREFER_PUBLIC=false
# If false, disable websocket event subscriptions and rely on polling only.
NEXT_PUBLIC_ENABLE_WS_EVENTS=true

# ── GENESIS RESERVE CONTRACTS (Arbitrum One — from deployment manifest) ──────
NEXT_PUBLIC_GENESIS_VAULT_ADDRESS=0xe164997D48395B4e24aB0f9F66c57DEA38C5E041
NEXT_PUBLIC_STRATEGY_ROUTER_ADDRESS=0xD7ff8383eBBE3B1023d95A3f14c32D9941Ac9e84
NEXT_PUBLIC_COMPLIANCE_REGISTRY_ADDRESS=0x6D58678562387c400964737884E78f2f12e1c495
NEXT_PUBLIC_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# ── GENESIS API GATEWAY ──────────────────────────────────────────────────────
NEXT_PUBLIC_GENESIS_API_URL=http://localhost:3001
GENESIS_BACKEND_URL=http://localhost:4000
GENESIS_PARTNER_API_KEY=your_partner_api_key_here
GENESIS_ADMIN_API_KEY=your_admin_api_key_here
# Production: https://api.genesisreserve.io

# ── STRIPE CARD PROCESSOR (server-side only) ────────────────────────────────
# Get both keys from dashboard.stripe.com → Developers → API keys
# Use test keys (sk_test_xxx / pk_test_xxx) locally, live keys in production.
# Set CARD_ISSUING_PROVIDER=stripe to enable live Stripe card flows.
CARD_ISSUING_PROVIDER=mock
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Max allowed webhook timestamp drift in seconds.
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# ── STRIPE TAP TO PAY (Apple Pay / Google Pay) ───────────────────────────────
# Google Pay merchant ID — issued after registering at pay.google.com/business/console
# Leave blank to use Stripe's shared merchant ID during development.
NEXT_PUBLIC_GOOGLE_PAY_MERCHANT_ID=
#
# Apple Pay domain verification:
#   1. Go to dashboard.stripe.com → Settings → Payment methods → Apple Pay
#   2. Add your production domain (e.g. app.genesisreserve.io)
#   3. Download the domain association file Stripe provides
#   4. Replace the placeholder in public/.well-known/apple-developer-merchantid-domain-association
#   Stripe handles merchant session validation automatically — no extra backend needed.

# ── STRIPE PUSH-TO-CARD PAYOUT PATHS (pick one) ─────────────────────────────
# Path A — Stripe Treasury (ACH / bank-to-bank; not instant card payouts):
#   Set to a Treasury FinancialAccount ID (fa_xxx) on the Genesis Reserve platform account.
#   destination_payment_method must be a us_bank_account PaymentMethod, not a card PM.
STRIPE_FINANCIAL_ACCOUNT_ID=
#
# Path B — Stripe Connect (required for instant card payouts):
#   Each user's linked debit card must be registered as an external account on a
#   Stripe connected account. Store the connected account ID on the LinkedDebitCard
#   record (connectedAccountId field) during card linking.
#   No single env var here — connectedAccountId comes from the LinkedDebitCard record.
#   See stripe-card-adapter.ts stripeCreatePushToCardPayout() for the full flow.

# ── CIRCLE (NON-CUSTODIAL USDC ON-RAMP) ──────────────────────────────────────
# Non-custodial flow: user's Circle-tokenized card → Circle Payments API →
# USDC minted natively on Arbitrum to user's Privy wallet via CCTP.
# Genesis never holds USDC — no platform wallet or pre-funded reserve required.
#
# Card tokenization: the user's card must be registered with Circle's card SDK
# (separate from the Stripe SetupIntent used for push-to-card payouts).
# The frontend calls Circle's card SDK to obtain a circleCardId, stored on
# LinkedDebitCard alongside Stripe's processorTokenRef.
#
# Get from console.circle.com → API Keys
CIRCLE_API_KEY=
# Optional shared secret — set in Circle's notification subscription settings
# and here to validate incoming webhook calls at POST /api/gr/webhooks/circle.
CIRCLE_WEBHOOK_SECRET=

# ── CARD SERVICE PERSISTENCE (optional) ─────────────────────────────────────
# If set, card-service API routes use PostgreSQL instead of in-memory storage.
# Example (local): postgresql://postgres:postgres@localhost:5432/genesis_ledger
DATABASE_URL=
# Set false for local Postgres without TLS. Defaults to true when unset.
DATABASE_SSL=false

# ── COMPLIANCE REGISTRY ADMIN/WRITER (server-side only) ───────────────────
# Dedicated signer that receives COMPLIANCE_WRITER role and can activate users.
COMPLIANCE_WRITER_PRIVATE_KEY=
COMPLIANCE_WRITER_ADDRESS=
# Existing deployer/admin signer used once to grant COMPLIANCE_WRITER role.
COMPLIANCE_ADMIN_PRIVATE_KEY=

# ── DEFRAME (Vault Strategy Discovery) ───────────────────────────────────────
# Required for live strategy scanning. Without this key, vault strategies use
# local fallback data only.
DEFRAME_API_KEY=5f313c21030b4b2682a5b537dc963d8b
# Optional override if your provider endpoint differs from the default.
DEFRAME_BASE_URL=https://api.deframe.io
# Accelerate scan tuning (dev): allow low-risk candidates only when APY clears
# this minimum. Stage-1 default floor remains separate for medium/high.
DEFRAME_ACCELERATE_STAGE1_MIN_APY_PCT=4
DEFRAME_ACCELERATE_STAGE1_LOW_RISK_MIN_APY_PCT=5
# Include instant liquidity in accelerate stage-1 filtering.
DEFRAME_ACCELERATE_STAGE1_INCLUDE_INSTANT=true
# Promote specific instant low-risk protocols to medium for accelerate scoring
# and gating so high-liquidity opportunities can compete in stage-1.
DEFRAME_ACCELERATE_INSTANT_RISK_PROMOTION_ENABLED=true
DEFRAME_ACCELERATE_INSTANT_RISK_PROMOTION_PROTOCOLS=aave,sky,lido
# Auto-promote any chain into effective scope when watchlist eligibility is met
# (lend enabled, not paused, APY threshold, and minimum candidate count).
DEFRAME_CHAIN_WATCHLIST_ENABLED=true
DEFRAME_CHAIN_WATCHLIST_MIN_APY_PCT=4
DEFRAME_CHAIN_WATCHLIST_MIN_CANDIDATES=1

# ── CHAIN ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=42161
# Arbitrum One. For testnet: 421614 (Arbitrum Sepolia)
